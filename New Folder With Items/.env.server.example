# Copy to .env.server.local and keep real values local only.
# SignalWire is the active ASAP CRM voice/SMS provider.
# The app still keeps /api/twilio/* route names because SignalWire's Compatibility API
# and webhook payloads are Twilio-compatible.
# SIGNALWIRE_PHONE_NUMBER is used as the default outbound caller ID and inbound webhook destination check.
# SIGNALWIRE_WEBHOOK_BASE_URL should be the hosted public API base URL.
# Local-only ngrok sessions work for testing, but production uses the Supabase Edge Function.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_CALL_ANALYSIS_MODEL=gpt-4o-mini
TELEPHONY_PROVIDER=signalwire
SIGNALWIRE_SPACE_URL=caseless-industries-llc.signalwire.com
SIGNALWIRE_PROJECT_ID=your-signalwire-project-id
SIGNALWIRE_API_TOKEN=your-signalwire-api-token
SIGNALWIRE_SIGNING_KEY=your-signalwire-signing-key
SIGNALWIRE_PHONE_NUMBER=+15615769819
SIGNALWIRE_MANAGED_PHONE_NUMBERS=+15615769819
# Legacy Twilio variable names remain supported as fallbacks for compatibility only.
# Prefer the SIGNALWIRE_* names above for ASAP's current deployment.
TWILIO_ACCOUNT_SID=your-provider-project-id
TWILIO_AUTH_TOKEN=your-provider-api-token
TWILIO_API_BASE_URL=https://caseless-industries-llc.signalwire.com/api/laml/2010-04-01
TWILIO_PHONE_NUMBER=+15615769819
TWILIO_MANAGED_PHONE_NUMBERS=+15615769819
ASSISTANT_OFFICE_PHONE_NUMBER=+15555550111
LUMIA_INVOICE_SMS_PHONE_NUMBER=+15555550123
SIGNALWIRE_VOICE_FORWARD_TO=+15555550111
TWILIO_VOICE_FORWARD_TO=+15555550111
# Answerable office/staff phone for outbound click-to-call. Do not set this to the SignalWire business number.
SIGNALWIRE_CLICK_TO_CALL_AGENT_NUMBER=+15555550111
TWILIO_CLICK_TO_CALL_AGENT_NUMBER=+15555550111
# Future browser calling only. Keep these server-side and never expose them through Vite.
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your-twilio-api-key-secret
# Configure this TwiML App voice request URL:
# https://your-public-webhook-base-url.example.com/api/twilio/browser-call/twiml
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
THUMBTACK_ASSISTANT_PHONE_NUMBER=+201001234567
THUMBTACK_WEBHOOK_SECRET=replace-with-a-long-random-secret
TWILIO_CLICK_TO_CALL_AUTO_COOLDOWN_HOURS=24
TWILIO_CLICK_TO_CALL_MISSED_SMS_DELAY_SECONDS=120
TWILIO_CLICK_TO_CALL_MISSED_SMS_BODY=Hi {{customerName}}, this is ASAP Appliances. I just tried calling about your appliance issue. Reply with your address and appliance details and we'll get you scheduled.
WORKFLOW_DISPATCH_HEADS_UP_MINUTES=60
WORKFLOW_TECHNICIAN_RESPONSE_FOLLOWUP_MINUTES=15
WORKFLOW_FINAL_ALERT_LEAD_MINUTES=10
WORKFLOW_PAYMENT_FOLLOWUP_MINUTES=8
WORKFLOW_LABOR_INVOICE_AMOUNT=150
SIGNALWIRE_WEBHOOK_BASE_URL=https://nexkymqahpkvzzlvivfi.supabase.co/functions/v1/asap-crm
SIGNALWIRE_WEBHOOK_PORT=8787
TWILIO_WEBHOOK_BASE_URL=https://nexkymqahpkvzzlvivfi.supabase.co/functions/v1/asap-crm
TWILIO_WEBHOOK_PORT=8787
