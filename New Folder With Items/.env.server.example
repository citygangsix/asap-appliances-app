# Copy to .env.server.local and keep real values local only.
# TWILIO_WEBHOOK_BASE_URL should be the current public tunnel base URL for this session.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+12145551000
ASSISTANT_OFFICE_PHONE_NUMBER=+15555550111
LUMIA_INVOICE_SMS_PHONE_NUMBER=+15555550123
WORKFLOW_DISPATCH_HEADS_UP_MINUTES=60
WORKFLOW_FINAL_ALERT_LEAD_MINUTES=10
WORKFLOW_PAYMENT_FOLLOWUP_MINUTES=8
WORKFLOW_LABOR_INVOICE_AMOUNT=150
TWILIO_WEBHOOK_BASE_URL=https://your-public-webhook-base-url.example.com
TWILIO_WEBHOOK_PORT=8787
