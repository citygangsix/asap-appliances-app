# Copy to .env.server.local and keep real values local only.
# TWILIO_PHONE_NUMBER is the active ASAP CRM Twilio business line.
# It is used as the default outbound caller ID and as the inbound webhook destination check.
# TWILIO_WEBHOOK_BASE_URL should be the hosted public API base URL.
# Local-only ngrok sessions work for testing, but production uses the Supabase Edge Function.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_CALL_ANALYSIS_MODEL=gpt-4o-mini
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+18445424212
TWILIO_MANAGED_PHONE_NUMBERS=+18445424212
ASSISTANT_OFFICE_PHONE_NUMBER=+15555550111
LUMIA_INVOICE_SMS_PHONE_NUMBER=+15555550123
TWILIO_VOICE_FORWARD_TO=+15555550111
# Answerable office/staff phone for outbound click-to-call. Do not set this to TWILIO_PHONE_NUMBER.
TWILIO_CLICK_TO_CALL_AGENT_NUMBER=+15555550111
# Future browser calling only. Keep these server-side and never expose them through Vite.
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your-twilio-api-key-secret
# Configure this TwiML App voice request URL:
# https://your-public-webhook-base-url.example.com/api/twilio/browser-call/twiml
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
THUMBTACK_ASSISTANT_PHONE_NUMBER=+201001234567
THUMBTACK_WEBHOOK_SECRET=replace-with-a-long-random-secret
TWILIO_CLICK_TO_CALL_AUTO_COOLDOWN_HOURS=24
TWILIO_CLICK_TO_CALL_MISSED_SMS_DELAY_SECONDS=120
TWILIO_CLICK_TO_CALL_MISSED_SMS_BODY=Hi {{customerName}}, this is ASAP Appliances. I just tried calling about your appliance issue. Reply with your address and appliance details and we'll get you scheduled.
WORKFLOW_DISPATCH_HEADS_UP_MINUTES=60
WORKFLOW_TECHNICIAN_RESPONSE_FOLLOWUP_MINUTES=15
WORKFLOW_FINAL_ALERT_LEAD_MINUTES=10
WORKFLOW_PAYMENT_FOLLOWUP_MINUTES=8
WORKFLOW_LABOR_INVOICE_AMOUNT=150
TWILIO_WEBHOOK_BASE_URL=https://nexkymqahpkvzzlvivfi.supabase.co/functions/v1/asap-crm
TWILIO_WEBHOOK_PORT=8787
