{
  "name": "asap-operations-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dashboard": "vite build --outDir dist-dashboard",
    "build:site": "vite build --config vite.site.config.js",
    "build:pages": "npm run build:site && npm run build:dashboard && node scripts/assemble-pages.mjs",
    "build:pages:hosted": "VITE_LOCAL_OPERATIONS_SERVER_URL=https://nexkymqahpkvzzlvivfi.supabase.co/functions/v1/asap-crm npm run build:pages",
    "check:pages-routes": "node scripts/check-pages-routes.mjs",
    "check:dashboard-auth": "node scripts/check-dashboard-auth.mjs",
    "check:supabase-live": "node scripts/check-supabase-live-contract.mjs",
    "check:server-env": "node scripts/check-server-env.mjs",
    "check:hosted-env": "node scripts/check-server-env.mjs hosted",
    "preview": "vite preview",
    "api:prepare": "node scripts/prepare-edge-function.mjs",
    "api:deploy": "npm run api:prepare && supabase functions deploy asap-crm --use-api --no-verify-jwt --import-map supabase/functions/import_map.json",
    "signalwire:webhooks": "node server/twilioWebhookServer.js",
    "signalwire:webhooks:smoke": "node server/twilioWebhookSmokeTest.js",
    "twilio:webhooks": "node server/twilioWebhookServer.js",
    "twilio:webhooks:smoke": "node server/twilioWebhookSmokeTest.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "@twilio/voice-sdk": "^2.18.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.10"
  }
}
