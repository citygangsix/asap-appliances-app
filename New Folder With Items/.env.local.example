VITE_APP_DATA_SOURCE=supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_LOCAL_OPERATIONS_SERVER_URL=http://127.0.0.1:8787
# Hosted production should point at the Supabase Edge Function base URL:
# VITE_LOCAL_OPERATIONS_SERVER_URL=https://nexkymqahpkvzzlvivfi.supabase.co/functions/v1/asap-crm
# Optional public site API override. This is not a secret.
VITE_PUBLIC_SERVICE_REQUEST_API_URL=http://127.0.0.1:8787
# Local public site submissions should dry-run unless you intentionally want live lead creation.
VITE_PUBLIC_SERVICE_REQUEST_DRY_RUN=true
# Dashboard login uses Supabase Auth email/password users from this project.
# Do not put dashboard passwords or service-role keys in VITE_* variables.
